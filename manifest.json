{
   "background": {
      "persistent": true,
      "scripts": [ "background.js" ]
   },
   "browser_action": {
      "default_icon": {
         "128": "icons/icon128.png",
         "16": "icons/icon16.png",
         "32": "icons/icon32.png",
         "48": "icons/icon48.png"
      },
      "default_popup": "popup.html",
      "default_title": "Network Logger"
   },
   "browser_specific_settings": {
      "gecko": {
         "data_collection_permissions": {
            "required": [ "none" ]
         },
         "id": "network-logger-har-exporter@example.local",
         "strict_min_version": "140.0"
      },
      "gecko_android": {
         "strict_min_version": "142.0"
      }
   },
   "description": "Capture network requests across all tabs and export as a HAR file — no DevTools needed. Perfect for debugging and sharing logs.",
   "homepage_url": "https://themindfuel-ai.github.io/network-logger/",
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
   },
   "manifest_version": 2,
   "name": "Network Logger - HAR Exporter",
   "permissions": [ "storage", "webRequest", "webRequestBlocking", "downloads", "\u003Call_urls>" ],
   "version": "1.2.0"
}
